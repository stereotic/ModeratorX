# App
NODE_ENV=development
LOG_LEVEL=debug
PROCESS_ROLE=all

# HTTP (OAuth callback)
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# Telegram
TELEGRAM_BOT_TOKEN=

# Twitter / X API (OAuth 2.0)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=http://localhost:3000/auth/twitter/callback

# OpenRouter (API-compatible with OpenAI)
OPENAI_API_KEY=your-openrouter-api-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_MAX_CONCURRENCY=5

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/x_moderator

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OAuth / tokens
OAUTH_STATE_TTL_SECONDS=600
TOKEN_REFRESH_SKEW_SECONDS=300

# Encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Product limits (Basic / pay-per-use friendly defaults)
DEFAULT_CHECK_INTERVAL=60
MIN_CHECK_INTERVAL=30
MAX_CHECK_INTERVAL=600
MAX_MONITORED_TWEETS_PER_ACCOUNT=20
MAX_TWITTER_ACCOUNTS_PER_USER=5
DEFAULT_CONFIDENCE_THRESHOLD=0.75
